{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "DevPulse.Infrastructure.Services": "Information",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DevPulse": "Server=localhost;Port=5432;Database=devpulse;User Id=postgres;Password=your_password;"
  },
  "S3Settings": {
    "BucketName": "devpulse-files",
    "Region": "us-east-1",
    "UrlTemplate": "https://{0}.s3.amazonaws.com/{1}",
    "RequestTimeoutSeconds": 300
  },
  "AllowedHosts": "*"
}
